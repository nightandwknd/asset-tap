# Rust build artifacts
target/
**/*.rs.bk
*.pdb

# Environment files
.env
.env.local
.env.*.local

# Local development files (dev mode stores all user data in .dev/)
.dev/

# macOS
.DS_Store

# IDE files (keep .vscode/ for shared settings)
.idea/

# Claude Code runtime artifacts (session lockfiles, etc.)
.claude/

# Logs
*.log

# Packaging artifacts
*.app
*.dmg
*.exe
*.msi
*.deb
*.rpm
*.AppImage

# Coverage reports
*.profraw
*.profdata
coverage.json
coverage-summary.txt
tarpaulin-report.html

# Test output (generated by scripts/test_cli.sh)
test_results/

# Zola site build output
site/public/
